# ============================================================================
# CloudInfinit API Gateway - Docker Environment Variables
# Copy to .env and customize for your deployment
# ============================================================================

# ─── Platform ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://cloudinfinit:cloudinfinit_secret@mysql:3306/cloudinfinit_apigw
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-characters
VITE_APP_TITLE=CloudInfinit API Gateway

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_PASSWORD=cloudinfinit_secret

# ─── MongoDB (Gravitee) ──────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret

# ─── Gravitee ─────────────────────────────────────────────────────────────────
GRAVITEE_API_TOKEN=your-gravitee-personal-access-token
GRAVITEE_ORG_ID=DEFAULT
GRAVITEE_ENV_ID=DEFAULT
GRAVITEE_ADMIN_PASSWORD=admin

# ─── Domain (for production) ──────────────────────────────────────────────────
DOMAIN=apigw.yourdomain.com
